# SKSecurity Environment Variables
# Copy to .env and fill in values for your deployment.

# --- AI Analysis (Ollama) ---
# Ollama base URL for AI-powered security analysis.
# Default: http://localhost:11434
# SKSECURITY_AI_URL=http://localhost:11434

# Ollama model name for security analysis.
# Default: llama3.2
# SKSECURITY_AI_MODEL=llama3.2

# Request timeout in seconds for AI analysis calls.
# Default: 60
# SKSECURITY_AI_TIMEOUT=60

# Enable AI-powered analysis globally (set to any truthy value).
# SKSECURITY_AI=

# --- Workspace ---
# Root workspace directory for security audits and dashboards.
# Default: ~/clawd
# SKSECURITY_WORKSPACE=~/clawd

# --- Debug ---
# Enable debug output for SKSecurity modules.
# SKSECURITY_DEBUG=
